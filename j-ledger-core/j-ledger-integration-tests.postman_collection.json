{
  "info": {
    "_postman_id": "jledger-headless-v1",
    "name": "J-Ledger BFF Integration",
    "description": "System-wide integration verification for J-Ledger Headless Architecture.\n\nStructure:\n1. Wallet API (External): Customer-facing endpoints.\n2. Admin API (External): Staff-facing endpoints.\n3. Core Engine (Internal): Direct ledger logic (requires X-Internal-Secret).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "gateway", "value": "http://localhost:8080", "type": "string" },
    { "key": "wallet_api", "value": "http://localhost:3002", "type": "string" },
    { "key": "admin_api", "value": "http://localhost:3001", "type": "string" },
    { "key": "internal_secret", "value": "jledger_ecosystem_secret_2024", "type": "string" },
    { "key": "customer_token", "value": "", "type": "string" },
    { "key": "admin_token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Wallet API (External)",
      "item": [
        {
          "name": "1.1 Register Customer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@jledger.local\",\n  \"password\": \"password123\",\n  \"pin\": \"123456\"\n}"
            },
            "url": { "raw": "{{wallet_api}}/users/register", "host": ["{{wallet_api}}"], "path": ["users", "register"] }
          }
        },
        {
          "name": "1.2 Customer Login",
          "event": [{
            "listen": "test",
            "script": { "exec": ["const body = pm.response.json();", "pm.collectionVariables.set('customer_token', body.access_token);"], "type": "text/javascript" }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@jledger.local\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{wallet_api}}/auth/login", "host": ["{{wallet_api}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "1.3 Execute Transfer (BFF)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customer_token}}" },
              { "key": "Idempotency-Key", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fromAccountId\": \"00000000-0000-0000-0000-000000000001\",\n  \"toAccountId\": \"00000000-0000-0000-0000-000000000002\",\n  \"amount\": \"100.00\",\n  \"currency\": \"THB\",\n  \"pin\": \"123456\"\n}"
            },
            "url": { "raw": "{{wallet_api}}/transactions/transfer", "host": ["{{wallet_api}}"], "path": ["transactions", "transfer"] }
          }
        }
      ]
    },
    {
      "name": "2. Admin API (External)",
      "item": [
        {
          "name": "2.1 Admin Login (Placeholder)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{admin_api}}/auth/login", "host": ["{{admin_api}}"], "path": ["auth", "login"] }
          }
        }
      ]
    },
    {
      "name": "3. Core Engine (Internal)",
      "item": [
        {
          "name": "3.1 Get All Eureka Apps",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Internal-Secret", "value": "{{internal_secret}}" }
            ],
            "url": { "raw": "http://localhost:8761/eureka/apps", "protocol": "http", "host": ["localhost"], "port": "8761", "path": ["eureka", "apps"] }
          }
        },
        {
          "name": "3.2 Health Check (Gateway Path)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Internal-Secret", "value": "{{internal_secret}}" }
            ],
            "url": { "raw": "{{gateway}}/api/core/actuator/health", "host": ["{{gateway}}"], "path": ["api", "core", "actuator", "health"] }
          }
        }
      ]
    }
  ]
}
