# -----------------------------------------------------------------------------
# J-Ledger LOCAL DEVELOPMENT Environment Variables (HOST Mode)
# คัดลอกไฟล์นี้ไปที่ .env เพื่อใช้สำหรับการรัน Service บนเครื่อง Mac (Host)
# -----------------------------------------------------------------------------

# 1. Database Configuration
POSTGRES_USER=ledger_admin
POSTGRES_PASSWORD=ledger_password
POSTGRES_DB=jledger_db

# 2. Redis Configuration
REDIS_PASSWORD=redis_password

# 3. Security Secrets
JWT_SECRET=jledger_secret_2024
JWT_REFRESH_SECRET=jledger_refresh_secret_2024
JLEDGER_INTERNAL_SECRET=jledger_ecosystem_secret_2024

# 4. Infrastructure URLs (ใช้ localhost เพราะ Infra อยู่ใน Docker แต่ Service อยู่บน Host)
JLEDGER_EUREKA_ZONE=http://localhost:8761/eureka/
JLEDGER_DATASOURCE_URL=jdbc:postgresql://localhost:5432/jledger_db
JLEDGER_REDIS_ADDRESS=redis://localhost:6379
JLEDGER_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# 5. Portal Configuration
JLEDGER_ALLOWED_ORIGINS=*
# Internal API URL (Used by Next.js Server-side/SSR to talk to BFF)
INTERNAL_API_URL=http://admin-api:3001

# 6. Admin User Credentials
JLEDGER_ADMIN_EMAIL=admin@jledger.io
JLEDGER_ADMIN_PASSWORD=password123
