# -----------------------------------------------------------------------------
# J-Ledger Production Environment Variables Template
# Copy this file to .env and update values for your production environment.
# -----------------------------------------------------------------------------

# 1. Database Configuration
POSTGRES_USER=ledger_admin
POSTGRES_PASSWORD=change_this_password_in_production
POSTGRES_DB=jledger_db

# 2. Redis Configuration
REDIS_PASSWORD=change_this_redis_password

# 3. Security Secrets
# Use a strong random string (e.g., openssl rand -base64 32)
JLEDGER_INTERNAL_SECRET=jledger_ecosystem_secret_2024

# 4. Infrastructure URLs (Override if needed, defaults are service names)
JLEDGER_EUREKA_ZONE=http://eureka-server:8761/eureka/
JLEDGER_DATASOURCE_URL=jdbc:postgresql://postgres:5432/jledger_db
JLEDGER_REDIS_ADDRESS=redis://redis:6379
JLEDGER_KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# 5. Portal Configuration
# For Client-side, this is usually relative ''
# For Server-side (SSR), use the internal gateway URL
NEXT_PUBLIC_API_GATEWAY_URL=http://api-gateway:8080

# 6. Admin User Credentials
JLEDGER_ADMIN_EMAIL=admin@jledger.io
JLEDGER_ADMIN_PASSWORD=change_this_admin_password
