# -----------------------------------------------------------------------------
# J-Ledger Notification Service LOCAL DEVELOPMENT Environment Variables
# คัดลอกไฟล์นี้ไปที่ .env.local เพื่อใช้สำหรับการรัน notification-service บนเครื่อง (Hybrid Mode)
# -----------------------------------------------------------------------------

# 1. Kafka Configuration
JLEDGER_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# 2. Eureka Configuration
JLEDGER_EUREKA_ZONE=http://localhost:8761/eureka/
