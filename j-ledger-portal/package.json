{
  "name": "j-ledger-portal",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "postinstall": "turbo run generate"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "@repo/prettier-config": "*",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.6.0",
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
