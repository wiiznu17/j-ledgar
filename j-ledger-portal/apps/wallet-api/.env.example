# -----------------------------------------------------------------------------
# Wallet API Environment Variables Example (Local Development)
# Copy this file to .env and fill in the actual values
# -----------------------------------------------------------------------------

# Server Port
PORT=3002

# Database Configuration
# For Hybrid Development (Docker infra + local service):
DATABASE_URL="postgresql://ledger_admin:ledger_password@localhost:5432/jledger_db?schema=wallet_schema"

# API Gateway Configuration (for internal microservice calls)
API_GATEWAY_URL="http://localhost:8080"

# Authentication
# Ensure these match the secrets in admin-web and j-ledger-core
JWT_ACCESS_SECRET="jledger-local-dev-jwt-access-secret"
JWT_REFRESH_SECRET="jledger-local-dev-jwt-refresh-secret"
JWT_REGISTRATION_SECRET="jledger-local-dev-jwt-registration-secret"

# Internal Security
JLEDGER_INTERNAL_SECRET="jledger_ecosystem_secret_2024"

# Redis Configuration (for Hybrid Development)
JLEDGER_REDIS_ADDRESS="redis://localhost:6379"
JLEDGER_REDIS_PASSWORD="redis_password"

# Kafka Configuration (for Hybrid Development - use external port)
JLEDGER_KAFKA_BOOTSTRAP_SERVERS="localhost:9092"

# Admin Credentials
JLEDGER_ADMIN_EMAIL="admin@jledger.io"
JLEDGER_ADMIN_PASSWORD="password123"

# S3/Storage Configuration
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="your_s3_access_key"
S3_SECRET_KEY="your_s3_secret_key"
S3_BUCKET="jledger-uploads"
S3_REGION="us-east-1"

# KYC Encryption Key
KYC_ENCRYPTION_KEY="your_kyc_encryption_key_32_bytes"

# SMS Provider
SMS_PROVIDER_TYPE="twilio"

# KYC Providers
KYC_OCR_PROVIDER_TYPE="google"
KYC_FACE_PROVIDER_TYPE="google"

# Storage Provider
STORAGE_PROVIDER_TYPE="s3"

# Google Cloud Configuration
GOOGLE_APPLICATION_CREDENTIALS="/path/to/google-key.json"
FIREBASE_PROJECT_ID="your_firebase_project_id"
FIREBASE_CLIENT_EMAIL="your_firebase_client_email"
FIREBASE_PRIVATE_KEY="your_firebase_private_key"

# AWS Configuration
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your_aws_access_key"
AWS_SECRET_ACCESS_KEY="your_aws_secret_key"

# Rate Limiting (Optional - defaults provided)
THROTTLE_TTL_DEFAULT=60000
THROTTLE_LIMIT_DEFAULT=100
THROTTLE_TTL_REG_INIT=300000
THROTTLE_LIMIT_REG_INIT=10
THROTTLE_TTL_REG_VERIFY=180000
THROTTLE_LIMIT_REG_VERIFY=10
THROTTLE_TTL_LOGIN=900000
THROTTLE_LIMIT_LOGIN=10
