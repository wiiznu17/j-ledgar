# -----------------------------------------------------------------------------
# Admin API Environment Variables Example (NestJS)
# Copy this file to .env and fill in the actual values
# -----------------------------------------------------------------------------

# Server Port
PORT=3001

# Database Configuration
# For Hybrid Development (Docker infra + local service):
DATABASE_URL="postgresql://ledger_admin:ledger_password@localhost:5432/jledger_db?schema=admin_schema"

# For Production (Docker):
# DATABASE_URL="postgresql://ledger_admin:ledger_password@postgres:5432/jledger_db?schema=admin_schema"

# API Gateway Configuration (for internal microservice calls)
# For Hybrid Development:
API_GATEWAY_URL="http://localhost:8080"

# For Production:
# API_GATEWAY_URL="http://api-gateway:8080"

# Authentication
# Ensure these match the secrets in admin-web and j-ledger-core
JWT_SECRET="jledger-local-dev-jwt-secret"
JWT_REFRESH_SECRET="jledger-local-dev-refresh-secret"

# Internal Security
JLEDGER_INTERNAL_SECRET="jledger_ecosystem_secret_2024"

# Backend Service URLs (for proxy calls)
# For Hybrid Development:
ADMIN_AUTH_SERVICE_URL="http://localhost:3002"
USER_KYC_SERVICE_URL="http://localhost:3003"
WALLET_SERVICE_URL="http://localhost:8080"

# For Production:
# ADMIN_AUTH_SERVICE_URL="http://admin-auth-service:3002"
# USER_KYC_SERVICE_URL="http://user-kyc-service:3003"
# WALLET_SERVICE_URL="http://wallet-service:8080"

# Admin Credentials
JLEDGER_ADMIN_EMAIL="admin@jledger.io"
JLEDGER_ADMIN_PASSWORD="password123"
