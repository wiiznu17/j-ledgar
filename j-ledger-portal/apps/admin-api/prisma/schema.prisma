generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/@prisma/client-admin"
  binaryTargets   = ["native", "linux-musl", "linux-musl-arm64-openssl-3.0.x"]
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["admin_schema", "public"]
}

model AdminUser {
  id               String   @id @default(uuid())
  email            String   @unique
  passwordHash     String
  refreshTokenHash String?
  role             String   @default("SUPPORT_STAFF")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("admin_users")
  @@schema("admin_schema")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
  @@schema("admin_schema")
}

model AuditLog {
  id              String   @id @default(uuid())
  adminUserId     String
  action          String
  resourceType    String
  resourceId      String
  ipAddress       String
  userAgent       String
  requestPayload  Json?
  responseStatus  Int
  changes         Json?
  reason          String?
  createdAt       DateTime @default(now())

  @@map("audit_logs")
  @@schema("admin_schema")
}
