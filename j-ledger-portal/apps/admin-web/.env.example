# -----------------------------------------------------------------------------
# Admin Web Environment Variables Example (Next.js)
# Copy this file to .env and fill in the actual values
# -----------------------------------------------------------------------------

# API Configuration
# INTERNAL_API_URL is only needed for server-side fetches (SSR/Actions)
# For Hybrid Development (local admin-api):
INTERNAL_API_URL=http://localhost:3001

# For Production (Docker):
# INTERNAL_API_URL=http://admin-api:3001

# Authentication
JWT_SECRET="jledger-local-dev-jwt-secret"

