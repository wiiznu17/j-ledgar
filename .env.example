# -----------------------------------------------------------------------------
# J-Ledger Environment Variables Example
# Copy this file to .env and fill in the actual values
# -----------------------------------------------------------------------------

# Database Configuration
POSTGRES_USER=ledger_admin
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=jledger_db

# Redis Configuration
REDIS_PASSWORD=your_redis_password_here

# Security Secrets
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JLEDGER_INTERNAL_SECRET=your_internal_secret_here

# JWT Secrets for Wallet API
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_REGISTRATION_SECRET=your_jwt_registration_secret_here

# Admin Credentials
JLEDGER_ADMIN_EMAIL=admin@jledger.io
JLEDGER_ADMIN_PASSWORD=your_admin_password_here

# S3/Storage Configuration
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key
S3_BUCKET=jledger-uploads
S3_REGION=us-east-1

# SMS Provider
SMS_PROVIDER_TYPE=twilio

# KYC Providers
KYC_OCR_PROVIDER_TYPE=google
KYC_FACE_PROVIDER_TYPE=google
KYC_ENCRYPTION_KEY=your_kyc_encryption_key_32_bytes

# Storage Provider
STORAGE_PROVIDER_TYPE=s3

# Google Cloud Configuration
GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-key.json
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY=your_firebase_private_key

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Rate Limiting (Optional - defaults provided)
THROTTLE_TTL_DEFAULT=60000
THROTTLE_LIMIT_DEFAULT=100
THROTTLE_TTL_REG_INIT=300000
THROTTLE_LIMIT_REG_INIT=10
THROTTLE_TTL_REG_VERIFY=180000
THROTTLE_LIMIT_REG_VERIFY=10
THROTTLE_TTL_LOGIN=900000
THROTTLE_LIMIT_LOGIN=10
